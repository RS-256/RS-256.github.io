---
import { Icon } from "astro-icon/components"
import { categories, type Work } from "../data/works"
import { Image } from "astro:assets"

/**
 * Detail dialog for a work. Opened by any element with
 * data-dialog-target={dialogId} (see the shared handler in BaseLayout).
 */
interface Props {
  work: Work
  dialogId: string
}
const { work, dialogId } = Astro.props
const categoryLabel = categories.find( ( c ) => c.id === work.category )?.label

const chips = [
  work.links.site && {
    href: work.links.site,
    icon: "lucide:external-link",
    label: "Open Site",
    primary: true
  },
  work.links.download && {
    href: work.links.download,
    icon: "lucide:download",
    label: "Download",
    primary: true
  },
  work.links.source && {
    href: work.links.source,
    icon: "simple-icons:github",
    label: "View Source",
    primary: false
  }
].filter( ( c ) => !! c )
---

<dialog
  id={dialogId}
  style={`--cat-field: var(--cat-${work.category}-field); --cat-ink: var(--cat-${work.category}-ink);`}
  class="m-auto w-[calc(100%-2rem)] max-w-lg rounded-3xl border border-line bg-surface p-0 text-ink shadow-2xl backdrop:bg-black/50 backdrop:backdrop-blur-sm"
>
  <div class="p-6 sm:p-8">
    <div class="flex items-start gap-4">
      {
        work.icon ? (
          <Image
            src={work.icon}
            alt=""
            width={Math.min(work.icon.width, 128)}
            height={Math.min(work.icon.height, 128)}
            class:list={[
              "size-16 rounded-2xl object-cover",
              work.pixelated && "[image-rendering:pixelated]",
            ]}
          />
        ) : (
          <div class="flex size-16 items-center justify-center rounded-2xl bg-(--cat-field) font-display text-2xl font-bold text-(--cat-ink)">
            {work.title.charAt(0)}
          </div>
        )
      }
      <div class="min-w-0 flex-1">
        <h3 class="font-display text-xl font-bold">{work.title}</h3>
        {
          categoryLabel && (
            <span class="mt-1.5 inline-block rounded-full bg-(--cat-field) px-2.5 py-0.5 text-xs font-medium text-(--cat-ink)">
              {categoryLabel}
            </span>
          )
        }
      </div>
      <button
        type="button"
        data-dialog-close
        aria-label="閉じる"
        class="-m-2 shrink-0 cursor-pointer rounded-full p-2 text-muted transition-colors hover:bg-surface-hover hover:text-ink"
      >
        <Icon name="lucide:x" class="size-5" />
      </button>
    </div>

    <p class="mt-5 text-sm leading-relaxed text-muted">
      {work.details ?? work.description}
    </p>

    <div class="mt-6 flex flex-wrap gap-2.5">
      {
        chips.map((chip) => (
          <a
            href={chip.href}
            target="_blank"
            rel="noopener noreferrer"
            class:list={[
              "inline-flex items-center gap-2 rounded-full px-4 py-2 text-sm font-bold transition-all duration-200 hover:-translate-y-0.5 hover:shadow-md hover:shadow-accent/15",
              chip.primary
                ? "bg-accent-soft text-accent-strong"
                : "border border-line text-ink hover:border-accent/40 hover:text-accent-strong",
            ]}
          >
            <Icon name={chip.icon} class="size-4" />
            {chip.label}
          </a>
        ))
      }
    </div>
  </div>
</dialog>
