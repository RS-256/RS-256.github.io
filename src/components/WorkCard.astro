---
import { Image } from "astro:assets";
import { Icon } from "astro-icon/components";
import { categories, type Work } from "../data/works";
import WorkDialog from "./WorkDialog.astro";

interface Props {
  work: Work;
  /** Hide under category headings, such as on the /works page. */
  showCategory?: boolean;
}
const { work, showCategory = true } = Astro.props;
const categoryLabel = categories.find((c) => c.id === work.category)?.label;
const dialogId = `work-dialog-${work.id}`;
---

<button
  type="button"
  data-dialog-target={dialogId}
  class="group flex w-full cursor-pointer gap-4 rounded-2xl border border-line bg-surface p-5 text-left shadow-sm transition-all duration-200 hover:-translate-y-0.5 hover:border-accent/40 hover:shadow-lg hover:shadow-accent/10"
>
  <div class="shrink-0">
    {
      work.icon ? (
        <Image
          src={work.icon}
          alt=""
          width={Math.min(work.icon.width, 112)}
          height={Math.min(work.icon.height, 112)}
          class:list={[
            "size-14 rounded-xl object-cover",
            work.pixelated && "[image-rendering:pixelated]",
          ]}
        />
      ) : (
        <div class="flex size-14 items-center justify-center rounded-xl bg-gradient-to-br from-glow-a to-glow-b font-display text-xl font-bold text-accent-strong">
          {work.title.charAt(0)}
        </div>
      )
    }
  </div>
  <div class="min-w-0">
    <div class="flex items-center gap-1.5">
      <h3
        class="truncate font-display text-base font-bold text-ink underline decoration-transparent decoration-2 underline-offset-4 transition-all group-hover:text-accent group-hover:decoration-accent/50"
      >
        {work.title}
      </h3>
      <Icon
        name="lucide:maximize-2"
        class="size-3.5 shrink-0 text-muted opacity-0 transition-opacity group-hover:opacity-100"
      />
    </div>
    <p class="mt-1 line-clamp-2 text-sm leading-relaxed text-muted">
      {work.description}
    </p>
    {
      showCategory && categoryLabel && (
        <span class="mt-2.5 inline-block rounded-full bg-accent-soft px-2.5 py-0.5 text-xs font-medium text-accent-strong">
          {categoryLabel}
        </span>
      )
    }
  </div>
</button>

<WorkDialog work={work} dialogId={dialogId} />
