---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import NoteCard from "../../components/NoteCard.astro";

const notes = (await getCollection("notes")).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
---

<BaseLayout title="Notes" description="開発メモや技術記事など。">
  <header class="pb-10 pt-14 sm:pt-20">
    <h1 class="font-display text-3xl font-extrabold tracking-tight sm:text-4xl">
      Notes<span class="text-accent">.</span>
    </h1>
    <p class="mt-3 text-muted">開発メモや技術記事など、書きものを置いています。</p>
  </header>

  <div class="flex flex-col gap-4 pb-4">
    {notes.map((note) => <NoteCard note={note} />)}
  </div>
</BaseLayout>
